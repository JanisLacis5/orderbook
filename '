#pragma once

#include "apiConstants.h"
#include <array>
#include <cstdint>

struct FormattedMessage {
    uint32_t totalLen;
    uint32_t callID;
};

class IMessager {
public: 
    virtual FormattedMessage& decode(std::array<std::byte, MAX_MESSAGE_LEN>& raw) = 0;
    virtual std::array<std::byte, MAX_MESSAGE_LEN> serialize(FormattedMessage& mes) = 0;
};

class Messager : public IMessager {
public:
    FormattedMessage& decode(std::array<std::byte, MAX_MESSAGE_LEN>& raw) override;
    std::array<std::byte, MAX_MESSAGE_LEN> serialize(FormattedMessage& mes) override;
};
